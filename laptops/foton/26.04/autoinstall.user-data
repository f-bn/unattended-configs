    conf: |
      # Suppress APT usage in scripts warning message
      Apt::Cmd::Disable-Script-Warning true;
  # - Updates -
  updates: all
  # - Packages -
  packages:
    - amberol
    - apache2-utils
    - apt-file
    - bind9-dnsutils
    - bind9-host
    - brave-browser
    - code
    - curl
    - docker.io
    - docker-clean
    - distrobox
    - fastfetch
    - fd-find
    - fonts-cascadia-code
    - fq
    - fzf
    - gawk
    - git
    - httpie
    - intel-gpu-tools
    - intel-media-va-driver-non-free
    - iputils-ping
    - jq
    - less
    - libjpeg-dev
    - libpam-u2f
    - librtlsdr0
    - lm-sensors
    - mycli
    - netcat-openbsd
    - nmap
    - nvme-cli
    - pgcli
    - pipx
    - powertop
    - python3-pip
    - ripgrep
    - rsync
    - rtl-sdr
    - s3cmd
    - simple-scan
    - socat
    - strace
    - systemd-container
    - systemd-cron
    - transmission-gtk
    - tcpdump
    - tio
    - tree
    - unzip
    - vainfo
    - vim
    - vlc
    - wget
    - wireguard-tools
    - yamllint
    - yq
    - zoxide
    - zsh
    - zstd
  snaps:
    - name: bruno
      channel: stable
    - name: bw
      channel: stable
    - name: chezmoi
      channel: stable
      classic: true
    - name: discord
      channel: stable
    - name: gradia
      channel: stable
    - name: kubectl
      channel: stable
      classic: true
    - name: multipass
      channel: stable
  # - Storage -
  storage:
    swap:
      filename: /swap
      size: 4GB
    config:
      ### Root disk
      - id: nvme-disk
        type: disk
        ptable: gpt
        path: /dev/nvme0n1
        preserve: false
        wipe: superblock-recursive
      ### EFI partition
      - id: nvme-efi-part
        type: partition
        device: nvme-disk
        number: 1
        size: 512MB
        grub_device: true
        flag: boot
      - id: nvme-efi-fs
        type: format
        volume: nvme-efi-part
        fstype: fat32
      - id: nvme-efi-mount
        type: mount
        device: nvme-efi-fs
        path: /boot/efi
      ### Boot partition
      - id: nvme-boot-part
        type: partition
        device: nvme-disk
        number: 2
        size: 1GB
      - id: nvme-boot-fs
        type: format
        volume: nvme-boot-part
        fstype: ext4
      - id: nvme-boot-mount
        type: mount
        device: nvme-boot-fs
        path: /boot
      ### LUKS partition
      - id: nvme-luks-part
        type: partition
        device: nvme-disk
        number: 3
        size: -1
      - id: nvme-luks-crypt
        type: dm_crypt
        dm_name: system-crypt
        volume: nvme-luks-part
        key: "<redacted>"
        options: ['luks','tries=0']
      - id: nvme-root-fs
        type: format
        volume: nvme-luks-crypt
        fstype: ext4
      - id: nvme-root-mount
        type: mount
        device: nvme-root-fs
        path: /
  # - Late commands -
  late-commands:
    # Install Feishin
    - curtin in-target -- wget -O /tmp/feishin.deb https://github.com/jeffvli/feishin/releases/latest/download/Feishin-linux-amd64.deb
    - curtin in-target -- apt install -y /tmp/feishin.deb
    - curtin in-target -- rm -f /tmp/feishin.deb
    # Switch to GNU coreutils
    - curtin in-target -- apt remove -y --allow-remove-essential coreutils-from-uutils
    # Remove unwanted packages
    - curtin in-target -- apt remove -y --purge gnome-characters kdump-tools rsyslog sysprof sysstat ubuntu-fan unattended-upgrades
    - curtin in-target -- apt autoremove -y --purge
    # Enable Docker daemon socket activation
    - curtin in-target -- systemctl disable docker.service
    - curtin in-target -- systemctl enable docker.socket
    # Enable PAM fingerprint authentication
    - curtin in-target -- pam-auth-update --enable fprintd
  # - Post-Installation -
  user-data:
    # Hostname
    hostname: foton
    manage_etc_hosts: true
    # Users and groups
    groups:
      - docker
    users:
      - name: fbobin
        gecos: "Florian Bobin"
        hashed_passwd: "<redacted>"
        lock_passwd: false
        groups: ['adm','docker','kvm','plugdev','sudo','systemd-journal']
        shell: /usr/bin/zsh
    write_files:
      - path: /etc/default/grub.d/kernel-preemption.cfg
        owner: 'root:root'
        permissions: '0644'
        content: |
          # Generated by cloud-init
          #
          GRUB_CMDLINE_LINUX_DEFAULT="$GRUB_CMDLINE_LINUX_DEFAULT preempt=full"
      - path: /etc/default/grub.d/zswap.cfg
        owner: 'root:root'
        permissions: '0644'
        content: |
          # Generated by cloud-init
          #
          GRUB_CMDLINE_LINUX_DEFAULT="$GRUB_CMDLINE_LINUX_DEFAULT zswap.enabled=1 zswap.compressor=zstd"
      - path: /etc/modprobe.d/blacklist-rtl28xxu.conf
        owner: 'root:root'
        permissions: '0644'
        content: |
          # Generated by cloud-init
          #
          # Blacklist RTL28xx drivers to avoid conflict with Osmocom RTL-SDR drivers
          blacklist dvb_usb_rtl28xxu
      - path: /etc/sysctl.d/90-swappiness.conf
        owner: 'root:root'
        permissions: '0644'
        content: |
          # Generated by cloud-init
          #
          vm.swappiness=100
      - path: /etc/syctl.d/90-watchdog.conf
        owner: "root:root"
        permissions: "0644"
        content: |
          # Generated by cloud-init
          #
          kernel.nmi_watchdog=0
      - path: /etc/systemd/journald.conf
        owner: 'root:root'
        permissions: '0644'
        content: |
          # Generated by cloud-init
          #
          # See journald.conf(5) for details.
          [Journal]
          Storage=persistent
          Compress=yes
          SystemMaxFileSize=256M
          RuntimeMaxUse=100M
      - path: /etc/tmpfiles.d/10-gdm-monitors-settings.conf
        owner: 'root:root'
        permissions: '0644'
        content: |
          # Generated by cloud-init
          #
          # Applies current desktop fractional scaling value to GDM to avoid it being
          # 'too zoomed-in'.
          r /etc/xdg/monitors.xml
          C /etc/xdg/monitors.xml 0644 root root - /home/fbobin/.config/monitors.xml
      - path: /etc/sudoers.d/00-defaults
        owner: 'root:root'
        permissions: '0440'
        content: |
          # Generated by cloud-init
          #
          Defaults passwd_timeout=1
      - path: /etc/bluetooth/main.conf
        owner: 'root:root'
        permissions: '0644'
        content: |
          # Generated by cloud-init
          #
          [Policy]
          AutoEnable=false
      - path: /etc/docker/daemon.json
        owner: 'root:root'
        permissions: '0644'
        content: |
          {
            "cgroup-parent": "docker.slice",
            "features": {
              "buildkit": true,
              "cdi": true,
              "containerd-snapshotter": true
            },
            "iptables": true,
            "live-restore": true,
            "log-driver": "local",
            "max-concurrent-downloads": 5,
            "max-concurrent-uploads": 5,
            "userland-proxy": false
          }
      - path: /usr/local/bin/brave-launcher
        owner: 'root:root'
        permissions: '0755'
        content: |
          #!/usr/bin/env bash
          set -euo pipefail
          XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
          BRAVE_FLAGS_FILE="${XDG_CONFIG_HOME}/brave-flags.conf"
          USER_FLAGS=()
          if [[ -f "${BRAVE_FLAGS_FILE}" ]]; then
            mapfile -t USER_FLAGS < "${BRAVE_FLAGS_FILE}"
          fi
          exec /usr/bin/brave-browser "$@" "${USER_FLAGS[@]-}"
    # Final commands
    runcmd:
      ### Uninstall Firefox
      - snap remove --purge firefox
      ### Refresh base snaps
      - snap refresh
      ### Allow Discord snap to observe system (to avoid errors messages)
      - snap connect discord:system-observe
      ### Update GRUB configuration
      - update-grub
    # Reboot machine at end of Cloud-Init run
    power_state:
      mode: reboot
      message: 'End of cloud-init run, reboot now'
      condition: true